ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_AGENT_ID=your_agent_id_here
CLAUDE_API_KEY=your_claude_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
# Transcription model — options (cheapest to most capable):
#   whisper-1                 $0.006/min  legacy
#   gpt-4o-mini-transcribe    $0.003/min  cheaper GPT-4o tier
#   gpt-4o-transcribe         $0.006/min  best accuracy, same cost as whisper-1
#   gpt-4o-transcribe-diarize $0.008/min  speaker-labelled output (default)
TRANSCRIPTION_MODEL=gpt-4o-transcribe-diarize
LEGISLATION_API_KEY=your_legislation_api_key_here
PORT=3000
