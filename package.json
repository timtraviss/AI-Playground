{
  "name": "investigative-interviewing-tutor",
  "version": "1.0.0",
  "description": "PEACE model investigative interviewing practice tool with ElevenLabs AI witness",
  "main": "server/index.js",
  "type": "module",
  "scripts": {
    "start": "node server/index.js",
    "dev": "node --watch server/index.js",
    "dev:all": "concurrently --names 'main,ddp' --prefix-colors 'cyan,blue' 'node --watch server/index.js' 'npm --prefix ddp-app run dev -- --port 3001'",
    "convert-pdf": "node scripts/convert-pdf.js",
    "test": "node --test tests/**/*.test.js",
    "heroku-postbuild": "node scripts/download-model.js && npm --prefix ddp-app install && npm --prefix ddp-app run db:generate && npm --prefix ddp-app run db:deploy && NEXT_PUBLIC_BASE_PATH=/ddp npm --prefix ddp-app run build"
  },
  "engines": {
    "node": "24.x"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@elevenlabs/client": "^1.1.2",
    "@huggingface/transformers": "^4.2.0",
    "bcrypt": "^6.0.0",
    "connect-pg-simple": "^10.0.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-session": "^1.19.0",
    "ffmpeg-static": "^5.3.0",
    "ffprobe-static": "^3.1.0",
    "fluent-ffmpeg": "^2.1.3",
    "http-proxy-middleware": "^3.0.5",
    "mammoth": "^1.12.0",
    "multer": "^2.1.1",
    "pdf-parse": "^1.1.1",
    "pg": "^8.20.0",
    "pizzip": "^3.2.0"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
